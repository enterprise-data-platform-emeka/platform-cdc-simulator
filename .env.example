# ── Environment ───────────────────────────────────────────────────────────────
# Controls how much data the simulator creates.
# dev = 5,000 max orders | staging = 10,000 | prod = 15,000
ENVIRONMENT=dev

# ── Database connection ───────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control — it is in .gitignore.
#
# For local development (after running make docker-up):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=localpass

# For AWS RDS (replace with your actual endpoint from Terraform output):
# DB_HOST=edp-dev-postgres.xxxxxx.eu-central-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=ecommerce
# DB_USER=postgres
# DB_PASSWORD=<your RDS password>

# ── Test database ─────────────────────────────────────────────────────────────
# The integration test suite connects to this database, NOT DB_NAME above.
# Keeping them separate means running tests can never wipe your simulator data.
TEST_DB_NAME=ecommerce_test

# ── Seed settings ─────────────────────────────────────────────────────────────
# These default to the values for your ENVIRONMENT above.
# Override them here only if you need non-standard amounts.
# SEED_CUSTOMERS=500
# SEED_PRODUCTS=200
# SEED_HISTORICAL_ORDERS=2000
SEED_RANDOM_SEED=42

# ── Simulation settings ───────────────────────────────────────────────────────
SIM_TICK_INTERVAL_SECONDS=2
SIM_NEW_ORDERS_PER_TICK=3
# SIM_MAX_ORDERS=5000    # defaults to ENVIRONMENT limit — override only if needed

# ── Retry settings ────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=5
RETRY_WAIT_MIN_SECONDS=1
RETRY_WAIT_MAX_SECONDS=30
