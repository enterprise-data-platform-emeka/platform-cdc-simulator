# ── Environment ───────────────────────────────────────────────────────────────
# Controls how much data the simulator creates and the order cap.
# Set this to match the environment this file is for:
#   dev     = 5,000 max orders
#   staging = 10,000 max orders
#   prod    = 15,000 max orders
ENVIRONMENT=

# ── How to use this file ──────────────────────────────────────────────────────
# Copy this file to a named env file and fill in your values.
# Never commit any .env* file — they are all in .gitignore.
#
# One file per target environment:
#   cp .env.example .env           → local Docker  (make schema)
#   cp .env.example .env.dev       → AWS dev RDS   (make schema ENV=dev)
#   cp .env.example .env.staging   → AWS staging   (make schema ENV=staging)
#   cp .env.example .env.prod      → AWS prod      (make schema ENV=prod)
#
# For local development (after running make docker-up):
# Local Docker defaults (after make docker-up):
# DB_HOST=localhost  DB_PORT=5432
#
# AWS RDS via SSM tunnel (after make apply ENV=dev/staging/prod):
# DB_HOST=localhost  DB_PORT=5433
DB_HOST=localhost
DB_PORT=
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=

# ── Test database ─────────────────────────────────────────────────────────────
# The integration test suite connects to this database, NOT DB_NAME above.
# Keeping them separate means running tests can never wipe your simulator data.
TEST_DB_NAME=ecommerce_test

# ── Seed settings ─────────────────────────────────────────────────────────────
# These default to the values for your ENVIRONMENT above.
# Override them here only if you need non-standard amounts.
# SEED_CUSTOMERS=500
# SEED_PRODUCTS=200
# SEED_HISTORICAL_ORDERS=2000
SEED_RANDOM_SEED=42

# ── Simulation settings ───────────────────────────────────────────────────────
SIM_TICK_INTERVAL_SECONDS=2
SIM_NEW_ORDERS_PER_TICK=3
# SIM_MAX_ORDERS=5000    # defaults to ENVIRONMENT limit — override only if needed

# ── Retry settings ────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=5
RETRY_WAIT_MIN_SECONDS=1
RETRY_WAIT_MAX_SECONDS=30
