# ── Database connection ───────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=changeme

# ── Seed settings ─────────────────────────────────────────────────────────────
# Number of customers, products, and historical orders to create on first seed.
SEED_CUSTOMERS=500
SEED_PRODUCTS=200
SEED_HISTORICAL_ORDERS=2000
SEED_RANDOM_SEED=42

# ── Simulation settings ───────────────────────────────────────────────────────
# How fast the simulator runs.
# TICK_INTERVAL_SECONDS: pause between each simulation tick.
# NEW_ORDERS_PER_TICK: how many new orders are placed each tick.
SIM_TICK_INTERVAL_SECONDS=2
SIM_NEW_ORDERS_PER_TICK=3

# ── Retry settings ────────────────────────────────────────────────────────────
# Controls reconnection behaviour if the database is unreachable.
RETRY_MAX_ATTEMPTS=5
RETRY_WAIT_MIN_SECONDS=1
RETRY_WAIT_MAX_SECONDS=30
